# Database
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge_code
REDIS_URL=redis://localhost:6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_ENABLED=true
# Group behavior: "all" (read all text messages) or "mention" (mentions/replies/commands only)
TELEGRAM_BOT_GROUP_MODE=all
# Optional public Mini App URL to show as Telegram "Open App" button in /start responses
TELEGRAM_MINIAPP_URL=https://your-domain.example
# Enable dev-mode auth bypass only for local development
TELEGRAM_DEV_AUTH=false

# JWT
JWT_SECRET=change-me-to-a-random-secret

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# App
SERVER_PORT=3001
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BOT_USERNAME=ForgeCodeBot
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false
