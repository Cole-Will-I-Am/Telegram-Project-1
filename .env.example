# Database
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge_code
REDIS_URL=redis://localhost:6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_ENABLED=true
# Group behavior: "all" (read all text messages) or "mention" (mentions/replies/commands only)
TELEGRAM_BOT_GROUP_MODE=all
# Optional public Mini App URL to show as Telegram "Open App" button in /start responses
TELEGRAM_MINIAPP_URL=https://your-domain.example
# Enable dev-mode auth bypass only for local development
TELEGRAM_DEV_AUTH=false

# JWT
JWT_SECRET=change-me-to-a-random-secret

# AI Provider — "ollama" (default), "openai", or "anthropic"
AI_PROVIDER=ollama

# Ollama cloud (default provider)
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODEL=minimax-m2.7:cloud

# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# App
SERVER_PORT=3001
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BOT_USERNAME=ForgeCodeBot
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false
